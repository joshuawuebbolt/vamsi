{
  "name": "vamsi",
  "displayName": "Vamsi",
  "description": "An AI coding coach    to help users  learn to code.",
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "vscode": "^1.105.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vamsi.helloWorld",
        "title": "Hello World"
      },
      {
        "command": "vamsi.daysSince",
        "title": "Days Since"
      },
      {
        "command": "vamsi.talkingLoop",
        "title": "Talking Loop"
      },
      {
        "command": "vamsi.playMp3",
        "title": "Play MP3"
      },
      {
        "command": "vamsi.synthesizeElevenLabs",
        "title": "Text to Speech"
      },
      {
        "command": "vamsi.hintLoop",
        "title": "Hint Loop"
      }
    ]
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.105.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.36.0"
  },
  "dependencies": {
    "@elevenlabs/elevenlabs-js": "^2.20.1",
    "sound-play": "^1.1.0",
    "@google/genai": "^1.27.0",
    "dotenv": "^17.2.3"
  }
}
